    "reviews_EbHWjG": {
      "type": "reviews",
      "blocks": {
        "review_HWe4BV": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/green-and-white-marbled-coloring.jpg",
            "title": "— Arjun M.",
            "job": "Verified Buyer, Formals/Oxfords",
            "stars": 5,
            "text": "<p>The leather quality on my Oxfords is genuinely something else — soft yet structured, and it's only gotten better after a few wears. Worth every rupee.</p>"
          }
        },
        "review_U9mL3G": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/chef-selection.png",
            "title": "— Priya S.",
            "job": "Verified Buyer, Chappals & Sandals",
            "stars": 5,
            "text": "<p>I was skeptical about buying sandals online, but the fit was perfect and the finish looks far more premium than the price suggests. Already eyeing the loafers next.</p>"
          }
        },
        "review_BFdiqA": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/chef-selection.png",
            "title": "— Rohan K.",
            "job": "Verified Buyer, Derby",
            "stars": 4,
            "text": "<p>Bought a pair of Derbys for a wedding and got so many compliments. The stitching detail is something you notice in person, not just photos.</p>"
          }
        },
        "review_AhjBGB": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/chef-selection.png",
            "title": "— Sneha T.",
            "job": "Verified Buyer, Loafer",
            "stars": 5,
            "text": "<p>Comfortable from day one, no breaking-in period like most formal shoes. Delivery took a couple extra days but the product made up for it.</p>"
          }
        },
        "review_JbFGPU": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/chef-selection.png",
            "title": "— Kabir A.",
            "job": "Verified Buyer, Derby",
            "stars": 5,
            "text": "<p>I've bought formal shoes from a few premium brands before, but the finishing on my Derbys stood out immediately — clean stitching, solid sole, no rough edges anywhere. Feels handmade in the best way.</p>"
          }
        }
      },
      "block_order": [
        "review_HWe4BV",
