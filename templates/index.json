    "about_template_dPqq9d": {
      "type": "about-template",
      "blocks": {
        "introduce_QGGaYd": {
          "type": "introduce",
          "settings": {
            "image_intro": "shopify://shop_images/hero-mob-3_3b0de4d2-7f5d-4ee4-94f7-0612b2c413de.webp",
            "title_intro": "Made to Last, Not Just to Sell",
            "des_intro": "",
            "content_intro": "Cobbler and Co was founded in Zirakpur, Punjab, with a simple belief — that footwear should be made to last, not just to sell. Every pair we create passes through the hands of skilled craftsmen who bring years of traditional shoemaking expertise to modern silhouettes. From the leather we source to the stitching that holds each shoe together, nothing is rushed. This is footwear built the way it used to be — with patience, precision, and pride in every step."
          }
        },
        "service_84Xm4a": {
          "type": "service",
