{% doc %}
  @prompt
    create the left side image area (Portrait) and on right about the brand title and description area (textarea)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-brand-section__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    gap: {{ block.settings.gap }}px;
    align-items: stretch;
  }

  .ai-brand-section__image-area-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    display: flex;
    flex-direction: column;
  }

  .ai-brand-section__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-brand-section__image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-brand-section__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 400px;
  }

  .ai-brand-section__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-brand-section__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-brand-section__content-area-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.content_vertical_alignment }};
    padding: {{ block.settings.content_padding }}px;
    background-color: {{ block.settings.content_background_color }};
    border-radius: {{ block.settings.content_border_radius }}px;
  }

  .ai-brand-section__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-brand-section__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-brand-section__container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-brand-section__image-area-{{ ai_gen_id }} {
      flex: 0 0 auto;
      width: 100%;
    }

    .ai-brand-section__image-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-brand-section__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_font_size }}px * 0.8);
    }

    .ai-brand-section__description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_font_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-brand-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-section__container-{{ ai_gen_id }}">
    <div class="ai-brand-section__image-area-{{ ai_gen_id }}">
      <div class="ai-brand-section__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.brand_image %}
          <img
            src="{{ block.settings.brand_image | image_url: width: 1000 }}"
            alt="{{ block.settings.brand_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.brand_image.width }}"
            height="{{ block.settings.brand_image.height }}"
          >
        {% else %}
          <div class="ai-brand-section__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-brand-section__empty-state-{{ ai_gen_id }}">
              Next, add a brand image
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-brand-section__content-area-{{ ai_gen_id }}">
      {% if block.settings.brand_title != blank %}
        <h2 class="ai-brand-section__title-{{ ai_gen_id }}">
          {{ block.settings.brand_title }}
        </h2>
      {% endif %}

      {% if block.settings.brand_description != blank %}
        <div class="ai-brand-section__description-{{ ai_gen_id }}">
          {{ block.settings.brand_description }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Brand story",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "brand_image",
      "label": "Brand image"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width",
      "min": 30,
      "max": 60,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "brand_title",
      "label": "Title",
      "default": "About our brand"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Description",
      "default": "We are passionate about creating quality products that inspire and delight our customers. Our journey began with a simple idea and has grown into a brand that values craftsmanship, sustainability, and innovation."
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title font size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Description font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Title spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "content_vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "content_border_radius",
      "label": "Content border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "content_background_color",
      "label": "Content background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between image and content",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Brand story"
    }
  ]
}
{% endschema %}
