{% doc %}
  @prompt
    Create a new Hero Slideshow section with the following features: smooth fade transition effect for both images and text when slides change, fully customizable settings including slide image, heading text, subheading text, button label and link, overlay color and opacity, text alignment, slide duration and autoplay speed, and the ability to add or remove slides. The section should be fully responsive across mobile, tablet, and desktop. Each slide should support a background image with an overlay, and animated text that fades in and out with the image transition. Include navigation dots and optional prev and next arrows.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-hero-slideshow__slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slide_height_desktop }}px;
  }

  .ai-hero-slideshow__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity {{ block.settings.transition_speed }}s ease-in-out;
  }

  .ai-hero-slideshow__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .ai-hero-slideshow__slide-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-slideshow__slide-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-slideshow__slide-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-slideshow__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  .ai-hero-slideshow__content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    z-index: 3;
    opacity: 0;
    transition: opacity {{ block.settings.transition_speed }}s ease-in-out;
  }

  .ai-hero-slideshow__slide-{{ ai_gen_id }}.active .ai-hero-slideshow__content-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-hero-slideshow__content-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-hero-slideshow__content-{{ ai_gen_id }}--left .ai-hero-slideshow__content-wrapper-{{ ai_gen_id }} {
    margin-right: auto;
  }

  .ai-hero-slideshow__content-{{ ai_gen_id }}--center .ai-hero-slideshow__content-wrapper-{{ ai_gen_id }} {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .ai-hero-slideshow__content-{{ ai_gen_id }}--right .ai-hero-slideshow__content-wrapper-{{ ai_gen_id }} {
    margin-left: auto;
    text-align: right;
  }

  .ai-hero-slideshow__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-hero-slideshow__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    line-height: 1.4;
  }

  .ai-hero-slideshow__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-slideshow__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
  }

  .ai-hero-slideshow__navigation-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 4;
  }

  .ai-hero-slideshow__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .ai-hero-slideshow__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  .ai-hero-slideshow__arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_bg_color }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 4;
    transition: all 0.3s ease;
    opacity: {{ block.settings.arrow_opacity }};
  }

  .ai-hero-slideshow__arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_bg_hover_color }};
    opacity: 1;
  }

  .ai-hero-slideshow__arrow-{{ ai_gen_id }}--prev {
    left: 20px;
  }

  .ai-hero-slideshow__arrow-{{ ai_gen_id }}--next {
    right: 20px;
  }

  .ai-hero-slideshow__arrow-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  @media screen and (max-width: 768px) {
    .ai-hero-slideshow__slides-{{ ai_gen_id }} {
      height: {{ block.settings.slide_height_mobile }}px;
    }

    .ai-hero-slideshow__content-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-hero-slideshow__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-hero-slideshow__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.7 }}px;
    }

    .ai-hero-slideshow__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }

    .ai-hero-slideshow__arrow-{{ ai_gen_id }} {
      width: {{ block.settings.arrow_size | times: 0.7 }}px;
      height: {{ block.settings.arrow_size | times: 0.7 }}px;
    }

    .ai-hero-slideshow__arrow-{{ ai_gen_id }}--prev {
      left: 10px;
    }

    .ai-hero-slideshow__arrow-{{ ai_gen_id }}--next {
      right: 10px;
    }
  }
{% endstyle %}

<hero-slideshow-{{ ai_gen_id }}
  class="ai-hero-slideshow-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.enable_autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-slideshow__slides-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
        assign slide_image_key = 'slide_' | append: i | append: '_image'
        assign slide_heading_key = 'slide_' | append: i | append: '_heading'
        assign slide_subheading_key = 'slide_' | append: i | append: '_subheading'
        assign slide_button_label_key = 'slide_' | append: i | append: '_button_label'
        assign slide_button_link_key = 'slide_' | append: i | append: '_button_link'
        assign slide_overlay_color_key = 'slide_' | append: i | append: '_overlay_color'
        assign slide_overlay_opacity_key = 'slide_' | append: i | append: '_overlay_opacity'
        assign slide_text_alignment_key = 'slide_' | append: i | append: '_text_alignment'

        assign slide_enabled = block.settings[slide_enabled_key]
        assign slide_image = block.settings[slide_image_key]
        assign slide_heading = block.settings[slide_heading_key]
        assign slide_subheading = block.settings[slide_subheading_key]
        assign slide_button_label = block.settings[slide_button_label_key]
        assign slide_button_link = block.settings[slide_button_link_key]
        assign slide_overlay_color = block.settings[slide_overlay_color_key]
        assign slide_overlay_opacity = block.settings[slide_overlay_opacity_key]
        assign slide_text_alignment = block.settings[slide_text_alignment_key]
      %}

      {% if slide_enabled %}
        <div class="ai-hero-slideshow__slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
          {% if slide_image %}
            <img
              src="{{ slide_image | image_url: width: 2000 }}"
              alt="{{ slide_image.alt | escape }}"
              class="ai-hero-slideshow__slide-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ slide_image.width }}"
              height="{{ slide_image.height }}"
            >
          {% else %}
            <div class="ai-hero-slideshow__slide-placeholder-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <div
            class="ai-hero-slideshow__overlay-{{ ai_gen_id }}"
            style="background-color: {{ slide_overlay_color }}; opacity: {{ slide_overlay_opacity }};"
          ></div>

          <div class="ai-hero-slideshow__content-{{ ai_gen_id }} ai-hero-slideshow__content-{{ ai_gen_id }}--{{ slide_text_alignment }}">
            <div class="ai-hero-slideshow__content-wrapper-{{ ai_gen_id }}">
              {% if slide_heading != blank %}
                <h2 class="ai-hero-slideshow__heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
              {% endif %}

              {% if slide_subheading != blank %}
                <p class="ai-hero-slideshow__subheading-{{ ai_gen_id }}">{{ slide_subheading }}</p>
              {% endif %}

              {% if slide_button_label != blank %}
                <a
                  href="{{ slide_button_link }}"
                  class="ai-hero-slideshow__button-{{ ai_gen_id }}"
                >
                  {{ slide_button_label }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% assign enabled_slides_count = 0 %}
  {% for i in (1..5) %}
    {% liquid
      assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
      assign slide_enabled = block.settings[slide_enabled_key]
    %}
    {% if slide_enabled %}
      {% assign enabled_slides_count = enabled_slides_count | plus: 1 %}
    {% endif %}
  {% endfor %}

  {% if enabled_slides_count > 1 %}
    <div class="ai-hero-slideshow__navigation-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign slide_enabled = block.settings[slide_enabled_key]
        %}
        {% if slide_enabled %}
          <button
            class="ai-hero-slideshow__dot-{{ ai_gen_id }}"
            data-slide-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_arrows %}
      <button
        class="ai-hero-slideshow__arrow-{{ ai_gen_id }} ai-hero-slideshow__arrow-{{ ai_gen_id }}--prev"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-hero-slideshow__arrow-{{ ai_gen_id }} ai-hero-slideshow__arrow-{{ ai_gen_id }}--next"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}
  {% endif %}
</hero-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.dots = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-hero-slideshow__slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-hero-slideshow__dot-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-hero-slideshow__arrow-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-hero-slideshow__arrow-{{ ai_gen_id }}--next');
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;

        if (this.slides.length === 0) return;

        this.showSlide(0);
        this.setupEventListeners();

        if (this.autoplay && this.slides.length > 1) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
            if (this.autoplay) {
              this.resetAutoplay();
            }
          });
        });

        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.previousSlide();
            if (this.autoplay) {
              this.resetAutoplay();
            }
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.nextSlide();
            if (this.autoplay) {
              this.resetAutoplay();
            }
          });
        }

        this.addEventListener('mouseenter', () => {
          if (this.autoplay) {
            this.stopAutoplay();
          }
        });

        this.addEventListener('mouseleave', () => {
          if (this.autoplay) {
            this.startAutoplay();
          }
        });
      }

      showSlide(index) {
        this.slides.forEach((slide, i) => {
          if (i === index) {
            slide.classList.add('active');
          } else {
            slide.classList.remove('active');
          }
        });

        this.dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        this.currentSlide = index;
      }

      goToSlide(index) {
        this.showSlide(index);
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.showSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.showSlide(prevIndex);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        this.stopAutoplay();
        this.startAutoplay();
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('hero-slideshow-{{ ai_gen_id }}', HeroSlideshow{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Hero slideshow",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Slideshow settings"
    },
    {
      "type": "range",
      "id": "slide_height_desktop",
      "label": "Desktop height",
      "min": 300,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 600
