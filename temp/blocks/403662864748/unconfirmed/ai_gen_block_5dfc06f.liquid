{% doc %}
  @prompt
    Add a customizable button below the description in the Brand Story block (section ID: template--27899184972140__17823692078188a59f, block ID: template--27899184972140__17823692078188a59f__ai_gen_block_65e3d05_bFKnwV). The button should have settings for button label text and button link URL, and should be styled to match the theme's existing button styles. It should appear below the description text in the Brand Story section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-story-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-brand-story-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-brand-story-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-weight: 600;
  }

  .ai-brand-story-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.description_spacing }}px;
  }

  .ai-brand-story-button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.button_margin_top }}px;
  }

  .ai-brand-story-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-brand-story-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-brand-story-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.section_padding | times: 0.7 }}px 15px;
    }

    .ai-brand-story-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-brand-story-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-brand-story-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-brand-story-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-story-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-brand-story-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-brand-story-description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {% endif %}

    {% if block.settings.button_label != blank and block.settings.button_link != blank %}
      <div class="ai-brand-story-button-wrapper-{{ ai_gen_id }}">
        <a href="{{ block.settings.button_link }}" class="ai-brand-story-button-{{ ai_gen_id }}">
          {{ block.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

